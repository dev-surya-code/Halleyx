# ── FlowForge v2.0 Environment Configuration ──

PORT=5000
NODE_ENV=development

# MongoDB — update for production (MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/flowforge_v2

# JWT — CHANGE THIS in production to a long random string
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=flowforge_dev_secret_CHANGE_THIS_IN_PRODUCTION_use_64_random_bytes
JWT_EXPIRES_IN=7d

# Frontend URL (CORS whitelist)
FRONTEND_URL=http://localhost:3000
